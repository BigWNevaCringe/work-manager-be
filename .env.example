# PostgreSQL
# When using Docker Compose, DB_HOST should be the PostgreSQL service name.
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=change_me
DB_NAME=work_manager

# Never enable schema synchronization in production. Use migrations instead.
DB_SYNC=false

# Application
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# Authentication
# Replace this with a long, random secret outside development.
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRATION_TIME=
JWT_REFRESH_EXPIRATION_TIME=

# Shared secret used by the Next.js Better Auth bridge when issuing Work Manager cookies.
BETTER_AUTH_BACKEND_SECRET=replace_with_the_same_value_as_frontend
